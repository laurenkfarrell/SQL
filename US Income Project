US Income Exploratory Analysis

## US Household Income Exploratory Data Analysis

SELECT * 
FROM us_project.us_household_income;

SELECT * 
FROM us_project.us_household_income_statistics;

## Which state has the most area of land

SELECT State_name, SUM(ALand), SUM(AWater)
FROM us_household_income
GROUP BY State_name
ORDER BY 2 DESC
;

## Which state has the most area of water

SELECT State_name, SUM(ALand), SUM(AWater)
FROM us_household_income
GROUP BY State_name
ORDER BY 3 DESC
;

## Identify the top 10 largest states by area of land

SELECT State_name, SUM(ALand), SUM(AWater)
FROM us_household_income
GROUP BY State_name
ORDER BY 2 DESC
LIMIT 10
;

## Identify the top 10 largest states by area of water

SELECT State_name, SUM(ALand), SUM(AWater)
FROM us_household_income
GROUP BY State_name
ORDER BY 3 DESC
LIMIT 10
;

## Conduct right join to identify where information is missing between tables

SELECT *
FROM us_household_income u
RIGHT JOIN us_household_income_statistics us
	ON u.id = us.id
WHERE u.id IS NULL
;

## Join tables and exclude records with missing data

SELECT *
FROM us_household_income u
INNER JOIN us_household_income_statistics us
	ON u.id = us.id
WHERE Mean <> 0
;

## Identify the 5 states with the lowest average mean income

SELECT u.State_name, ROUND(AVG(Mean),0), ROUND(AVG(Median),0)
FROM us_household_income u
INNER JOIN us_household_income_statistics us
	ON u.id = us.id
WHERE Mean <> 0
GROUP BY u.State_name
ORDER BY 2 ASC
LIMIT 5
;

## Identify the 10 states with the highest average median income

SELECT u.State_name, ROUND(AVG(Mean),0), ROUND(AVG(Median),0)
FROM us_household_income u
INNER JOIN us_household_income_statistics us
	ON u.id = us.id
WHERE Mean <> 0
GROUP BY u.State_name
ORDER BY 3 DESC
LIMIT 10
;

## Explore the average mean income per each Type

SELECT Type, COUNT(Type), ROUND(AVG(Mean),0), ROUND(AVG(Median),0)
FROM us_household_income u
INNER JOIN us_household_income_statistics us
	ON u.id = us.id
WHERE Mean <> 0
GROUP BY Type
ORDER BY 3 DESC
;

## Explore the average median income per each Type (excluding Type outliers)

SELECT Type, COUNT(Type), ROUND(AVG(Mean),0), ROUND(AVG(Median),0)
FROM us_household_income u
INNER JOIN us_household_income_statistics us
	ON u.id = us.id
WHERE Mean <> 0
GROUP BY Type
HAVING COUNT(Type) > 100
ORDER BY 4 DESC
;

## Find states that have communities

SELECT *
FROM us_household_income u
INNER JOIN us_household_income_statistics us
	ON u.id = us.id
WHERE Mean <> 0 
	AND Type = 'Community'
;

## Identify highest income cities

SELECT u.State_name, City, ROUND(AVG(Mean),0), ROUND(AVG(Median),0)
FROM us_household_income u
INNER JOIN us_household_income_statistics us
	ON u.id = us.id
GROUP BY u.State_name, City
ORDER BY 3 DESC
;
