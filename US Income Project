## Update column name

ALTER TABLE us_project.us_household_income_statistics RENAME COLUMN `ï»¿id` TO `id`;

## Count number of records in each table to identify any gaps between datasets

SELECT Count(id)
FROM us_household_income_statistics;

SELECT Count(id)
