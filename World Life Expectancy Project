Data Analysis

SELECT * FROM world_life_expectancy;

## Identify MIN and MAX Life expectancy of each country and the difference in Life expectancy (excluding countries with '0's in the dataset)

SELECT Country, 
MIN(`Life expectancy`), 
MAX(`Life expectancy`),
ROUND(MAX(`Life expectancy`) - MIN(`Life expectancy`),1) AS Life_Increase_15_Years
FROM world_life_expectancy
GROUP BY Country
HAVING MIN(`Life expectancy`) <> 0
AND MAX(`Life expectancy`) <> 0
ORDER BY Life_Increase_15_Years DESC
;

## Identify AVG Life expectancy per year (excluding '0's in the dataset)

SELECT Year, ROUND(AVG(`Life expectancy`), 2)
FROM world_life_expectancy
WHERE `Life expectancy` <> 0
GROUP BY Year
ORDER BY Year DESC
;

## Explore does higher GDP correlate with higer Life expectancy (excluding '0's in the dataset)

SELECT Country, ROUND(AVG(`Life expectancy`),1) AS Life_Exp, ROUND(AVG(GDP),1) AS GDP
FROM world_life_expectancy
GROUP BY Country
HAVING Life_Exp > 0
AND GDP > 0
ORDER BY GDP ASC
;

## Further exploring GDP and Life expectancy correlation (1250 being about halfway point in the dataset)

SELECT 
SUM(CASE WHEN GDP >= 1250 THEN 1 ELSE 0 END) High_GDP_Count,
AVG(CASE WHEN GDP >= 1250 THEN `Life expectancy` ELSE NULL END) High_GDP_Life_Exp,
SUM(CASE WHEN GDP <= 1250 THEN 1 ELSE 0 END) Low_GDP_Count,
AVG(CASE WHEN GDP <= 1250 THEN `Life expectancy` ELSE NULL END) Low_GDP_Life_Exp
FROM world_life_expectancy
;

## Exploring correlation of status to Life expectancy (including counting the number of countries in each status to identify potentially skewed data)

SELECT Status, COUNT(DISTINCT Country), ROUND(AVG(`Life expectancy`), 1)
FROM world_life_expectancy
GROUP BY Status
;

## Exploring correlation of BMI to Life expectancy (excluding '0's in the dataset)

SELECT Country, ROUND(AVG(`Life expectancy`),1) AS Life_Exp, ROUND(AVG(BMI),1) AS BMI
FROM world_life_expectancy
GROUP BY Country
HAVING Life_Exp > 0
AND BMI > 0
ORDER BY BMI 
;
